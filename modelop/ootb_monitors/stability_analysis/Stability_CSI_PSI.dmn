      <rule id="DecisionRule_0wpdvvw">
        <inputEntry id="UnaryTests_0x0f71b" expressionLanguage="groovy">
          <text>def result = [:]
result = stability[0]?.values
return result.any {entry-&gt;entry.any{it.value.stability_index&gt;0.2}}</text>
        </inputEntry>
        <inputEntry id="UnaryTests_09w28nx">
          <text>not("HIGH","MEDIUM","LOW")</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_0chavg8">
