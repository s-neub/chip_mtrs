        </outputEntry>
        <outputEntry id="LiteralExpression_1wrgh91">
          <text>"Stability index is greater than 0.2 for one or more features or model output fields"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_07k38xg">
          <text>"Stability"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0y2nos0">
          <text>"error"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_073eogu">
        <inputEntry id="UnaryTests_084ui3b" expressionLanguage="groovy">
          <text>def result = [:]
result = stability[0]?.values
return result.any {entry-&gt;entry.any{it.value.stability_index&gt;0.25}}</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0nc0erp">
          <text>"LOW"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_19xijko">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_1nfofft">
          <text>"Stability index is greater than 0.25 for one or more features or model output fields"</text>
