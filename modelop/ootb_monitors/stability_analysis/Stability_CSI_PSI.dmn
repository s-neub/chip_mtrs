  <decision id="Decision_0stvl36" name="Stability_CSI_PSI">
    <decisionTable id="DecisionTable_1tw8z54" hitPolicy="FIRST">
      <input id="Input_1" label="Stability" camunda:inputVariable="stability">
        <inputExpression id="InputExpression_1" typeRef="string" expressionLanguage="groovy">
          <text></text>
        </inputExpression>
      </input>
      <input id="InputClause_1vu9dlg" label="Model Risk" camunda:inputVariable="modelRisk">
        <inputExpression id="LiteralExpression_064e5m4" typeRef="string">
          <text></text>
        </inputExpression>
      </input>
      <output id="Output_1" label="Passes" name="passes" typeRef="boolean" />
      <output id="OutputClause_09mx2e6" label="Reason" name="reason" typeRef="string" />
      <output id="OutputClause_1o20aiw" label="Category" name="category" typeRef="string" />
      <output id="OutputClause_1xyk24f" label="Action" name="action" typeRef="string" />
      <rule id="DecisionRule_0bvgwrr">
        <inputEntry id="UnaryTests_1oysfty" expressionLanguage="groovy">
          <text>def result = [:]
result = stability[0]?.values
return result.any {entry-&gt;entry.any{it.value.stability_index&gt;0.15}}</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1914itj">
          <text>"HIGH"</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_04vpren">
          <text>false</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_1fj4998">
          <text>"Stability index is greater than 0.15 for one or more features or model output fields"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0pi465y">
          <text>"Stability"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0qx6jpm">
          <text>"error"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_01c1kxo">
        <inputEntry id="UnaryTests_0xdoshm" expressionLanguage="groovy">
          <text>def result = [:]
result = stability[0]?.values
return result.any {entry-&gt;entry.any{it.value.stability_index&gt;0.2}}</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1aie6c3">
